#!/bin/sh

# Get the previous HEAD, new HEAD, and checkout type
previous_head=$1
new_head=$2
checkout_type=$3

# Only run for branch checkouts (not file checkouts)
if [ $checkout_type -ne 1 ]; then
    exit 0
fi

current_branch=$(git rev-parse --abbrev-ref HEAD)
previous_branch=$(git name-rev --name-only $previous_head 2>/dev/null | sed 's/^remotes\/origin\///' || echo "unknown")

# Skip if switching to existing branch
if git show-ref --verify --quiet refs/heads/$current_branch 2>/dev/null; then
    # Branch already exists, check if it follows naming convention
    case "$current_branch" in
        main|master|development|develop)
            # Allow switching to main branches
            ;;
        feature/*|hotfix/*|release/*|bugfix/*)
            # Valid pattern
            ;;
        *)
            echo "" >&2
            echo "⚠️  Warning: Branch '$current_branch' doesn't follow naming convention!" >&2
            echo "✅ Expected patterns: feature/*, hotfix/*, release/*, bugfix/*" >&2
            echo "" >&2
            ;;
    esac
    exit 0
fi

# New branch created - validate pattern and parent
case "$current_branch" in
    hotfix/*)
        if [ "$previous_branch" != "main" ] && [ "$previous_branch" != "origin/main" ]; then
            echo "" >&2
            echo "❌ =================================" >&2
            echo "❌ HOTFIX MUST BE FROM MAIN!" >&2
            echo "❌ Created from: $previous_branch" >&2
            echo "❌ =================================" >&2
            echo "" >&2
            echo "✅ Correct way:" >&2
            echo "   git checkout main" >&2
            echo "   git checkout -b $current_branch" >&2
            echo "" >&2
            git checkout $previous_head
            git branch -D $current_branch
            exit 1
        fi
        ;;
    feature/*|release/*)
        if [ "$previous_branch" != "development" ] && [ "$previous_branch" != "develop" ] && [ "$previous_branch" != "origin/development" ] && [ "$previous_branch" != "origin/develop" ]; then
            branch_type="feature"
            [ "${current_branch#release/}" != "$current_branch" ] && branch_type="release"
            
            echo "" >&2
            echo "❌ =================================" >&2
            echo "❌ ${branch_type^^} MUST BE FROM DEVELOPMENT!" >&2
            echo "❌ Created from: $previous_branch" >&2
            echo "❌ =================================" >&2
            echo "" >&2
            echo "✅ Correct way:" >&2
            echo "   git checkout development" >&2
            echo "   git checkout -b $current_branch" >&2
            echo "" >&2
            git checkout $previous_head
            git branch -D $current_branch
            exit 1
        fi
        ;;
    bugfix/*)
        echo "🐛 Bugfix branch created: $current_branch"
        ;;
    main|master|development|develop)
        # Allow switching to main branches
        ;;
    *)
        echo "" >&2
        echo "❌ =================================" >&2
        echo "❌ INVALID BRANCH NAME!" >&2
        echo "❌ Branch: $current_branch" >&2
        echo "❌ =================================" >&2
        echo "" >&2
        echo "✅ Use these patterns:" >&2
        echo "   - feature/your-feature" >&2
        echo "   - hotfix/urgent-fix" >&2
        echo "   - release/v1.0.0" >&2
        echo "   - bugfix/fix-something" >&2
        echo "" >&2
        git checkout $previous_head
        git branch -D $current_branch
        exit 1
        ;;
esac

echo "✅ Branch '$current_branch' created successfully!"