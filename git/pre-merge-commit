#!/bin/sh
# Prevents merging into feature/* and release/* branches
# Triggers: git merge (when creating merge commit)

current_branch=$(git rev-parse --abbrev-ref HEAD)

echo "🔍 [pre-merge-commit] Checking merge into: $current_branch"

case "$current_branch" in
    feature/*|release/*)
        echo "" >&2
        echo "❌ =================================" >&2
        echo "❌ MERGE BLOCKED! (pre-merge-commit)" >&2
        echo "❌ Cannot merge into: $current_branch" >&2
        echo "❌ =================================" >&2
        echo "" >&2
        echo "✅ Use Pull Request workflow instead" >&2
        echo "" >&2
        exit 1
        ;;
esac

echo "✅ [pre-merge-commit] Merge validation passed!"
exit 0