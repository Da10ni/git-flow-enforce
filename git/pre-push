#!/bin/sh

echo "Remote: $1"
echo "URL: $2"

# Get current branch
current_branch=$(git rev-parse --abbrev-ref HEAD)
echo "Current branch: $current_branch"

# Block direct pushes to protected branches
case "$current_branch" in
    main|master|development|develop)
        echo "" >&2
        echo "❌ =================================" >&2
        echo "❌ DIRECT PUSH BLOCKED!" >&2
        echo "❌ Branch: $current_branch" >&2
        echo "❌ Use Pull Request workflow!" >&2
        echo "❌ =================================" >&2
        echo "" >&2
        echo "✅ Correct workflow:" >&2
        echo "   1. git checkout -b feature/your-feature" >&2
        echo "   2. git push origin feature/your-feature" >&2
        echo "   3. Create Pull Request on GitHub" >&2
        echo "" >&2
        exit 1
        ;;
esac

# Function to check if branch was created from specific parent
check_parent_branch() {
    local branch=$1
    local expected_parent=$2
    
    # Check if branch already exists on remote (skip parent check for existing branches)
    if git ls-remote --heads origin "$branch" 2>/dev/null | grep -q .; then
        echo "✅ Branch already exists on remote (skipping parent check)"
        return 0
    fi
    
    # For new branches, check immediate parent
    echo "🔍 Checking parent branch for new branch..."
    
    # Update refs to ensure we have latest info
    git fetch origin "$expected_parent" 2>/dev/null || true
    
    # Get the expected parent's latest commit
    local parent_commit=$(git rev-parse "origin/$expected_parent" 2>/dev/null || git rev-parse "$expected_parent" 2>/dev/null || echo "")
    if [ -z "$parent_commit" ]; then
        echo "❌ Parent branch '$expected_parent' not found!"
        return 1
    fi
    
    # Method 1: Check using reflog (most reliable for recently created branches)
    local branch_creation=$(git reflog show --format="%H %gs" "$current_branch" 2>/dev/null | grep -E "(branch: Created from|checkout: moving from)" | tail -n 1)
    
    if echo "$branch_creation" | grep -q "$expected_parent"; then
        echo "✅ Branch was created from $expected_parent (via reflog)"
        return 0
    fi
    
    # Method 2: For hotfix branches, check if they branched from main's lineage
    if [ "$expected_parent" = "main" ]; then
        # Get all commits in current branch
        local current_commits=$(git rev-list HEAD)
        
        # Get all commits in main
        local main_commits=$(git rev-list origin/main 2>/dev/null || git rev-list main 2>/dev/null)
        
        # Check if first unique commit's parent is in main's history
        local first_unique_commit=""
        for commit in $(git rev-list --reverse HEAD); do
            if ! echo "$main_commits" | grep -q "^$commit$"; then
                first_unique_commit=$commit
                break
            fi
        done
        
        if [ -n "$first_unique_commit" ]; then
            local first_parent=$(git rev-parse "$first_unique_commit^" 2>/dev/null || echo "")
            if echo "$main_commits" | grep -q "^$first_parent$"; then
                echo "✅ Branch was created from main's lineage"
                return 0
            fi
        else
            # No unique commits yet
            echo "✅ Branch has no unique commits yet"
            return 0
        fi
    fi
    
    # Method 3: For feature/release branches, ensure they came from development
    if [ "$expected_parent" = "development" ]; then
        # Check if the branch contains any commits that are in main but NOT in development
        # This would indicate it was created from main
        git fetch origin main 2>/dev/null || true
        
        # Get commits that are in main but not in development
        local main_only_commits=$(git rev-list origin/main --not origin/development 2>/dev/null || echo "")
        
        if [ -n "$main_only_commits" ]; then
            # Check if current branch contains any of these main-only commits
            for commit in $main_only_commits; do
                if git rev-list HEAD | grep -q "^$commit$"; then
                    echo "❌ Branch contains commits from main that are not in development!"
                    echo "❌ This indicates the branch was created from main instead of development"
                    echo "❌ Problematic commit: $commit"
                    return 1
                fi
            done
        fi
        
        # Additional check: Verify the branch diverged from development's history
        local dev_commits=$(git rev-list origin/development 2>/dev/null || git rev-list development 2>/dev/null)
        local first_unique_commit=""
        
        for commit in $(git rev-list --reverse HEAD); do
            if ! echo "$dev_commits" | grep -q "^$commit$"; then
                first_unique_commit=$commit
                break
            fi
        done
        
        if [ -n "$first_unique_commit" ]; then
            local first_parent=$(git rev-parse "$first_unique_commit^" 2>/dev/null || echo "")
            if echo "$dev_commits" | grep -q "^$first_parent$"; then
                echo "✅ Branch was created from development's lineage"
                return 0
            fi
        else
            # No unique commits yet
            echo "✅ Branch has no unique commits yet"
            return 0
        fi
    fi
    
    # If we reach here, branch wasn't created from expected parent
    echo "❌ Branch was NOT created from $expected_parent"
    return 1
}

# Special handling for branches that might be in merge process
is_branch_in_merge_process() {
    local branch=$1
    
    # Check if this branch has already been merged to main or development
    # This helps with the GitFlow process where hotfixes/releases get merged to multiple branches
    
    # Check if the branch has been merged to origin/main
    if git branch -r --merged origin/main 2>/dev/null | grep -q "origin/$branch"; then
        echo "ℹ️  Branch has been merged to main (likely in GitFlow merge process)"
        return 0
    fi
    
    # Check if the branch has been merged to origin/development
    if git branch -r --merged origin/development 2>/dev/null | grep -q "origin/$branch"; then
        echo "ℹ️  Branch has been merged to development (likely in GitFlow merge process)"
        return 0
    fi
    
    return 1
}

# Validate branch patterns and parent branches
case "$current_branch" in
    hotfix/*)
        echo "🏥 Validating hotfix branch: $current_branch"
        
        # Check if this hotfix is in merge process (already merged somewhere)
        if is_branch_in_merge_process "$current_branch"; then
            echo "✅ Hotfix branch is in merge process, skipping parent validation"
        elif ! check_parent_branch "$current_branch" "main"; then
            echo "" >&2
            echo "❌ =================================" >&2
            echo "❌ HOTFIX MUST BE FROM MAIN!" >&2
            echo "❌ Your branch: $current_branch" >&2
            echo "❌ =================================" >&2
            echo "" >&2
            echo "✅ Correct workflow:" >&2
            echo "   1. git checkout main" >&2
            echo "   2. git pull origin main" >&2
            echo "   3. git checkout -b $current_branch" >&2
            echo "" >&2
            echo "ℹ️  If you need to recreate the branch:" >&2
            echo "   git branch -D $current_branch" >&2
            echo "   git checkout main" >&2
            echo "   git checkout -b $current_branch" >&2
            echo "" >&2
            exit 1
        fi
        ;;
        
    feature/*)
        echo "✨ Validating feature branch: $current_branch"
        
        if ! check_parent_branch "$current_branch" "development"; then
            echo "" >&2
            echo "❌ =================================" >&2
            echo "❌ FEATURE MUST BE FROM DEVELOPMENT!" >&2
            echo "❌ Your branch: $current_branch" >&2
            echo "❌ =================================" >&2
            echo "" >&2
            echo "✅ Correct workflow:" >&2
            echo "   1. git checkout development" >&2
            echo "   2. git pull origin development" >&2
            echo "   3. git checkout -b $current_branch" >&2
            echo "" >&2
            echo "ℹ️  If you need to recreate the branch:" >&2
            echo "   git branch -D $current_branch" >&2
            echo "   git checkout development" >&2
            echo "   git checkout -b $current_branch" >&2
            echo "" >&2
            exit 1
        fi
        ;;
        
    release/*)
        echo "🚀 Validating release branch: $current_branch"
        
        # Check if this release is in merge process (already merged somewhere)
        if is_branch_in_merge_process "$current_branch"; then
            echo "✅ Release branch is in merge process, skipping parent validation"
        elif ! check_parent_branch "$current_branch" "development"; then
            echo "" >&2
            echo "❌ =================================" >&2
            echo "❌ RELEASE MUST BE FROM DEVELOPMENT!" >&2
            echo "❌ Your branch: $current_branch" >&2
            echo "❌ =================================" >&2
            echo "" >&2
            echo "✅ Correct workflow:" >&2
            echo "   1. git checkout development" >&2
            echo "   2. git pull origin development" >&2
            echo "   3. git checkout -b $current_branch" >&2
            echo "" >&2
            echo "ℹ️  If you need to recreate the branch:" >&2
            echo "   git branch -D $current_branch" >&2
            echo "   git checkout development" >&2
            echo "   git checkout -b $current_branch" >&2
            echo "" >&2
            exit 1
        fi
        ;;
        
    bugfix/*)
        echo "🐛 Bugfix branch pattern valid: $current_branch"
        echo "ℹ️  Bugfix branches can be created from any parent"
        ;;
        
    *)
        echo "" >&2
        echo "❌ =================================" >&2
        echo "❌ Invalid branch pattern!" >&2
        echo "❌ Your branch: $current_branch" >&2
        echo "❌ =================================" >&2
        echo "" >&2
        echo "✅ Allowed patterns:" >&2
        echo "   FROM main:" >&2
        echo "   - hotfix/*  (urgent fixes)" >&2
        echo "" >&2
        echo "   FROM development:" >&2
        echo "   - feature/* (new features)" >&2
        echo "   - release/* (release prep)" >&2
        echo "" >&2
        echo "   FROM any branch:" >&2
        echo "   - bugfix/*  (general fixes)" >&2
        echo "" >&2
        echo "Example: git branch -m feature/add-login" >&2
        echo "" >&2
        exit 1
        ;;
esac

echo "✅ All checks passed! Push allowed!"
exit 0